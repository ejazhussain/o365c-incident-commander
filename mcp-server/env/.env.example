# Incident Commander MCP Server - Environment Configuration

# Server
PORT=3001
HOST=127.0.0.1

# ngrok tunnel URL (update after starting ngrok)
# Run: ngrok http 3001
SERVER_BASE_URL=https://your-ngrok-url.ngrok-free.app

# OAuth / Entra ID (Phase 2)
# Azure Portal → App registrations → O365C - Incident Commander MCP Server → Overview
OAUTH_CLIENT_ID=your-application-client-id
OAUTH_TENANT_ID=your-directory-tenant-id
OAUTH_CLIENT_SECRET=your-client-secret-value
OAUTH_AUTHORITY=https://login.microsoftonline.com/your-directory-tenant-id
OAUTH_AUDIENCE=api://your-application-client-id
OAUTH_SCOPE=api://your-application-client-id/access_as_user

# Set to false to bypass auth for local MCP Inspector testing
# Set to true when deploying / testing with real tokens
AUTH_ENABLED=false